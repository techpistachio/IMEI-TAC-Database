            "key": "X-API-Key",
            "value": "{{apiKey}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/v1/tac/{{tac}}",
          "host": ["{{baseUrl}}"],
          "path": ["v1", "tac", "{{tac}}"]
        },
        "description": "Look up TAC metadata for an approved API key."
      },
